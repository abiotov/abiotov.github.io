---
// Fig 1 — ONE idea: context grows every turn; memory is what bounds it.
// Discipline: few shapes, big text, readable at arm's length.
const { num = '1' } = Astro.props;
---
<figure class="fig">
  <svg viewBox="0 0 720 330" role="img" aria-label="Two rows of bars. Without memory, the context grows every turn until it is huge. With memory, the context stays small and the overflow is absorbed by a memory store.">
    <defs>
      <marker id="f1a" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 1 L 9 5 L 0 9 z" fill="var(--muted)"></path>
      </marker>
    </defs>

    <!-- row A: without memory -->
    <text x="16" y="34" font-size="19" font-weight="600" fill="var(--ink)">without memory</text>
    <rect x="16"  y="56" width="56" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="88"  y="56" width="92" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="196" y="56" width="140" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="352" y="56" width="200" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="568" y="50" width="136" height="38" rx="6" fill="var(--ink)"></rect>
    <text x="636" y="74" text-anchor="middle" font-size="15" font-weight="600" fill="var(--bg)">you pay all of it</text>
    <text x="16" y="112" font-size="15" fill="var(--muted)">the context re-enters the model every turn, and every turn it is bigger</text>

    <!-- row B: with memory -->
    <text x="16" y="170" font-size="19" font-weight="600" fill="var(--ink)">with memory</text>
    <rect x="16"  y="192" width="56" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="88"  y="192" width="64" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="168" y="192" width="64" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="248" y="192" width="64" height="26" rx="6" fill="var(--line)"></rect>
    <rect x="328" y="192" width="64" height="26" rx="6" fill="var(--line)"></rect>
    <text x="416" y="211" font-size="15" fill="var(--muted)">stays small</text>

    <!-- overflow into the store -->
    <path d="M 200 226 C 200 258, 380 244, 560 262" fill="none" stroke="var(--muted)" stroke-width="2" marker-end="url(#f1a)"></path>
    <text x="330" y="266" font-size="15" fill="var(--muted)">everything else is written out ...</text>

    <path d="M 566 252 a 46 12 0 0 1 92 0 v 44 a 46 12 0 0 1 -92 0 z" fill="var(--line)" stroke="var(--ink)" stroke-width="2"></path>
    <ellipse cx="612" cy="252" rx="46" ry="12" fill="var(--line)" stroke="var(--ink)" stroke-width="2"></ellipse>
    <text x="612" y="285" text-anchor="middle" font-size="15" font-weight="600" fill="var(--ink)">memory</text>

    <!-- recall back -->
    <path d="M 560 300 C 380 316, 220 300, 168 232" fill="none" stroke="var(--muted)" stroke-width="2" stroke-dasharray="6 5" marker-end="url(#f1a)"></path>
    <text x="330" y="322" font-size="15" fill="var(--muted)">... and only what helps comes back</text>

    <!-- turn axis -->
    <text x="16" y="146" font-size="13" fill="var(--faint)">turn 1</text>
    <text x="704" y="146" text-anchor="end" font-size="13" fill="var(--faint)">turn 40</text>
    <line x1="60" y1="141" x2="660" y2="141" stroke="var(--faint)" stroke-width="1" stroke-dasharray="2 4"></line>
  </svg>
  <figcaption><strong>Fig. {num}.</strong> The whole memory problem in one picture. An agent re-reads its context on every turn, so an unmanaged context is a bill that compounds. Memory moves history out of the loop and lets only the useful part back in.</figcaption>
</figure>
