---
// Fig 1 — the agent loop, draw.io visual style (official palette pairs),
// hand-authored SVG so outside labels stay theme-aware. Editable source:
// diagrams/fig1-agent-loop.drawio.
const { num = '1' } = Astro.props;
const ink = '#2d2d2d'; // text inside pastel boxes: fixed for both themes
---
<figure class="fig">
  <svg viewBox="0 0 720 250" role="img" aria-label="Diagram of the agent loop: a task feeds a repeated cycle of memory, plan, act, observe; every observation becomes the next turn's input tokens, and memory is the only stage that can shrink what the others pay for.">
    <defs>
      <marker id="arrL" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 1 L 9 5 L 0 9 z" fill="var(--muted)"></path>
      </marker>
    </defs>

    <!-- task -->
    <rect x="10" y="100" width="76" height="46" rx="8" fill="#f5f5f5" stroke="#666666" stroke-width="1.6"></rect>
    <text x="48" y="128" text-anchor="middle" font-size="13.5" fill={ink} font-weight="600">task</text>
    <line x1="86" y1="123" x2="122" y2="123" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#arrL)"></line>

    <!-- loop container, drawio dotted -->
    <rect x="126" y="34" width="428" height="186" rx="10" fill="none" stroke="var(--faint)" stroke-width="1.4" stroke-dasharray="1.5 3"></rect>
    <text x="340" y="26" text-anchor="middle" font-size="11" fill="var(--faint)" letter-spacing="1.5">REPEATED EVERY TURN</text>

    <!-- memory (yellow pair) -->
    <rect x="146" y="100" width="88" height="46" rx="8" fill="#fff2cc" stroke="#d6b656" stroke-width="1.8"></rect>
    <text x="190" y="128" text-anchor="middle" font-size="13.5" fill={ink} font-weight="700">memory</text>
    <circle cx="190" cy="96" r="11" fill="#ffffff" stroke="#666666" stroke-width="1.3"></circle>
    <text x="190" y="100" text-anchor="middle" font-size="11" fill={ink}>1</text>

    <!-- plan (blue pair) -->
    <rect x="256" y="100" width="72" height="46" rx="8" fill="#dae8fc" stroke="#6c8ebf" stroke-width="1.8"></rect>
    <text x="292" y="128" text-anchor="middle" font-size="13.5" fill={ink}>plan</text>
    <circle cx="292" cy="96" r="11" fill="#ffffff" stroke="#666666" stroke-width="1.3"></circle>
    <text x="292" y="100" text-anchor="middle" font-size="11" fill={ink}>2</text>

    <!-- act (orange pair) -->
    <rect x="350" y="100" width="72" height="46" rx="8" fill="#ffe6cc" stroke="#d79b00" stroke-width="1.8"></rect>
    <text x="386" y="128" text-anchor="middle" font-size="13.5" fill={ink}>act</text>
    <circle cx="386" cy="96" r="11" fill="#ffffff" stroke="#666666" stroke-width="1.3"></circle>
    <text x="386" y="100" text-anchor="middle" font-size="11" fill={ink}>3</text>

    <!-- observe (green pair) -->
    <rect x="444" y="100" width="88" height="46" rx="8" fill="#d5e8d4" stroke="#82b366" stroke-width="1.8"></rect>
    <text x="488" y="128" text-anchor="middle" font-size="13.5" fill={ink}>observe</text>
    <circle cx="488" cy="96" r="11" fill="#ffffff" stroke="#666666" stroke-width="1.3"></circle>
    <text x="488" y="100" text-anchor="middle" font-size="11" fill={ink}>4</text>

    <line x1="234" y1="123" x2="252" y2="123" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#arrL)"></line>
    <line x1="328" y1="123" x2="346" y2="123" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#arrL)"></line>
    <line x1="422" y1="123" x2="440" y2="123" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#arrL)"></line>

    <!-- feedback curve -->
    <path d="M 488 146 C 488 186, 190 186, 190 150" fill="none" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#arrL)"></path>
    <text x="340" y="200" text-anchor="middle" font-size="12" fill="var(--muted)">every observation becomes next turn's input tokens</text>

    <!-- output -->
    <line x1="554" y1="123" x2="590" y2="123" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#arrL)"></line>
    <rect x="594" y="100" width="112" height="46" rx="8" fill="#f5f5f5" stroke="#666666" stroke-width="1.6"></rect>
    <text x="650" y="128" text-anchor="middle" font-size="13.5" fill={ink} font-weight="600">answer</text>

    <!-- annotation on memory -->
    <path d="M 190 74 C 190 56, 226 50, 246 50" fill="none" stroke="var(--faint)" stroke-width="1" stroke-dasharray="3 3"></path>
    <text x="254" y="54" font-size="12" fill="var(--muted)">the only stage that can shrink what all the others pay for</text>
  </svg>
  <figcaption><strong>Fig. {num}.</strong> The agent loop. Output of turn <em>n</em> becomes input cost of turn <em>n+1</em>; retries, redundant tool calls and long contexts all compound. Memory is the one component positioned to cut every term at once.</figcaption>
</figure>
