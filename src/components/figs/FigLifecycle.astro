---
// Fig 2 — the memory lifecycle as a real data pipeline: write path, stores,
// offline maintenance, read path. Monochrome, theme-aware, mono labels.
const { num = '2' } = Astro.props;
const mono = "'JetBrains Mono', monospace";
---
<figure class="fig">
  <svg viewBox="0 0 720 418" role="img" aria-label="Pipeline diagram of the memory lifecycle. Write path: conversations and tool traces pass a write gate into three stores (raw ledger, vector index, temporal graph). A maintenance worker runs offline over the stores: deduplicate, consolidate, decay. Read path: a query goes through retrieval over the stores, the selected memories are assembled into context for the LLM.">
    <defs>
      <marker id="sd2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M 0 1 L 9 5 L 0 9 z" fill="var(--muted)"></path>
      </marker>
    </defs>

    <!-- ===== WRITE PATH ===== -->
    <text x="16" y="26" font-size="11" font-family={mono} letter-spacing="1" fill="var(--faint)">WRITE PATH · every turn, must be cheap</text>

    <!-- source: conversations + traces (document icons) -->
    <path d="M 24 52 h 44 l 14 14 v 52 h -58 z" fill="var(--line)" stroke="var(--ink)" stroke-width="1.5"></path>
    <path d="M 68 52 v 14 h 14" fill="none" stroke="var(--ink)" stroke-width="1.5"></path>
    <line x1="34" y1="82" x2="70" y2="82" stroke="var(--muted)" stroke-width="1.3"></line>
    <line x1="34" y1="94" x2="70" y2="94" stroke="var(--muted)" stroke-width="1.3"></line>
    <line x1="34" y1="106" x2="58" y2="106" stroke="var(--muted)" stroke-width="1.3"></line>
    <text x="53" y="140" text-anchor="middle" font-size="10.5" font-family={mono} fill="var(--ink)">turns · tool</text>
    <text x="53" y="154" text-anchor="middle" font-size="10.5" font-family={mono} fill="var(--ink)">traces</text>

    <line x1="86" y1="88" x2="122" y2="88" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></line>

    <!-- write gate (1. construction) -->
    <rect x="126" y="56" width="118" height="66" rx="8" fill="none" stroke="var(--ink)" stroke-width="1.8"></rect>
    <text x="185" y="80" text-anchor="middle" font-size="11.5" font-family={mono} font-weight="700" fill="var(--ink)">write gate</text>
    <text x="185" y="97" text-anchor="middle" font-size="9.5" font-family={mono} fill="var(--muted)">extract · dedup</text>
    <text x="185" y="110" text-anchor="middle" font-size="9.5" font-family={mono} fill="var(--muted)">reject noise</text>
    <circle cx="136" cy="56" r="11" fill="var(--ink)"></circle>
    <text x="136" y="60" text-anchor="middle" font-size="10.5" font-family={mono} fill="var(--bg)">1</text>
    <text x="185" y="139" text-anchor="middle" font-size="9.5" font-family={mono} fill="var(--faint)">= construction</text>

    <line x1="244" y1="88" x2="282" y2="88" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></line>

    <!-- ===== STORES ===== -->
    <rect x="286" y="40" width="404" height="130" rx="10" fill="none" stroke="var(--faint)" stroke-width="1.4" stroke-dasharray="2 4"></rect>
    <text x="682" y="34" text-anchor="end" font-size="11" font-family={mono} letter-spacing="1" fill="var(--faint)">STORES</text>

    <path d="M 306 72 a 42 10 0 0 1 84 0 v 58 a 42 10 0 0 1 -84 0 z" fill="var(--line)" stroke="var(--ink)" stroke-width="1.5"></path>
    <ellipse cx="348" cy="72" rx="42" ry="10" fill="var(--line)" stroke="var(--ink)" stroke-width="1.5"></ellipse>
    <text x="348" y="105" text-anchor="middle" font-size="10.5" font-family={mono} font-weight="700" fill="var(--ink)">raw ledger</text>
    <text x="348" y="120" text-anchor="middle" font-size="9" font-family={mono} fill="var(--muted)">append-only</text>

    <path d="M 446 72 a 42 10 0 0 1 84 0 v 58 a 42 10 0 0 1 -84 0 z" fill="var(--line)" stroke="var(--ink)" stroke-width="1.5"></path>
    <ellipse cx="488" cy="72" rx="42" ry="10" fill="var(--line)" stroke="var(--ink)" stroke-width="1.5"></ellipse>
    <text x="488" y="105" text-anchor="middle" font-size="10.5" font-family={mono} font-weight="700" fill="var(--ink)">vector index</text>
    <text x="488" y="120" text-anchor="middle" font-size="9" font-family={mono} fill="var(--muted)">embeddings</text>

    <path d="M 586 72 a 42 10 0 0 1 84 0 v 58 a 42 10 0 0 1 -84 0 z" fill="var(--line)" stroke="var(--ink)" stroke-width="1.5"></path>
    <ellipse cx="628" cy="72" rx="42" ry="10" fill="var(--line)" stroke="var(--ink)" stroke-width="1.5"></ellipse>
    <text x="628" y="105" text-anchor="middle" font-size="10.5" font-family={mono} font-weight="700" fill="var(--ink)">temporal graph</text>
    <text x="628" y="120" text-anchor="middle" font-size="9" font-family={mono} fill="var(--muted)">validity-aware</text>

    <!-- ===== MAINTENANCE (2. management) ===== -->
    <rect x="286" y="196" width="404" height="64" rx="10" fill="none" stroke="var(--ink)" stroke-width="1.6"></rect>
    <circle cx="296" cy="196" r="11" fill="var(--ink)"></circle>
    <text x="296" y="200" text-anchor="middle" font-size="10.5" font-family={mono} fill="var(--bg)">2</text>
    <!-- gear icon -->
    <circle cx="322" cy="228" r="10" fill="none" stroke="var(--ink)" stroke-width="1.5"></circle>
    <circle cx="322" cy="228" r="3.5" fill="none" stroke="var(--ink)" stroke-width="1.3"></circle>
    <g stroke="var(--ink)" stroke-width="1.5">
      <line x1="322" y1="214" x2="322" y2="219"></line><line x1="322" y1="237" x2="322" y2="242"></line>
      <line x1="308" y1="228" x2="313" y2="228"></line><line x1="331" y1="228" x2="336" y2="228"></line>
      <line x1="312" y1="218" x2="316" y2="222"></line><line x1="328" y1="234" x2="332" y2="238"></line>
      <line x1="332" y1="218" x2="328" y2="222"></line><line x1="316" y1="234" x2="312" y2="238"></line>
    </g>
    <text x="348" y="224" font-size="11.5" font-family={mono} font-weight="700" fill="var(--ink)">maintenance worker · offline, budgeted</text>
    <text x="348" y="242" font-size="10" font-family={mono} fill="var(--muted)">consolidate · dedup · resolve conflicts · decay to cold</text>
    <text x="612" y="278" text-anchor="middle" font-size="9.5" font-family={mono} fill="var(--faint)">= management</text>

    <path d="M 400 196 C 400 184, 400 178, 400 170" fill="none" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></path>
    <path d="M 560 170 C 560 178, 560 184, 560 196" fill="none" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></path>

    <!-- ===== READ PATH (3. access) ===== -->
    <text x="16" y="296" font-size="11" font-family={mono} letter-spacing="1" fill="var(--faint)">READ PATH · per query</text>
    <text x="704" y="296" text-anchor="end" font-size="10" font-family={mono} fill="var(--faint)">pays rent in context tokens</text>

    <!-- query: magnifier -->
    <circle cx="46" cy="345" r="13" fill="none" stroke="var(--ink)" stroke-width="1.6"></circle>
    <line x1="55" y1="355" x2="66" y2="366" stroke="var(--ink)" stroke-width="1.8"></line>
    <text x="50" y="386" text-anchor="middle" font-size="10.5" font-family={mono} fill="var(--ink)">query</text>

    <line x1="72" y1="345" x2="106" y2="345" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></line>

    <rect x="110" y="318" width="130" height="56" rx="8" fill="none" stroke="var(--ink)" stroke-width="1.8"></rect>
    <text x="175" y="341" text-anchor="middle" font-size="11.5" font-family={mono} font-weight="700" fill="var(--ink)">retrieval</text>
    <text x="175" y="358" text-anchor="middle" font-size="9.5" font-family={mono} fill="var(--muted)">similarity != utility</text>
    <circle cx="120" cy="318" r="11" fill="var(--ink)"></circle>
    <text x="120" y="322" text-anchor="middle" font-size="10.5" font-family={mono} fill="var(--bg)">3</text>
    <text x="175" y="392" text-anchor="middle" font-size="9.5" font-family={mono} fill="var(--faint)">= access</text>

    <!-- stores feed retrieval -->
    <path d="M 348 170 C 348 260, 240 310, 220 322" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-dasharray="4 3" marker-end="url(#sd2)"></path>
    <text x="296" y="292" font-size="10" font-family={mono} fill="var(--muted)">top-k</text>

    <line x1="240" y1="345" x2="286" y2="345" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></line>

    <!-- assembled context -->
    <rect x="290" y="320" width="150" height="52" rx="6" fill="none" stroke="var(--ink)" stroke-width="1.5"></rect>
    <rect x="298" y="328" width="134" height="10" rx="2" fill="var(--ink)"></rect>
    <rect x="298" y="342" width="134" height="10" rx="2" fill="var(--line)"></rect>
    <rect x="298" y="356" width="100" height="10" rx="2" fill="var(--line)"></rect>
    <text x="365" y="390" text-anchor="middle" font-size="10.5" font-family={mono} fill="var(--ink)">assembled context</text>

    <line x1="440" y1="345" x2="486" y2="345" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></line>

    <!-- LLM chip -->
    <rect x="490" y="320" width="76" height="52" rx="8" fill="none" stroke="var(--ink)" stroke-width="1.8"></rect>
    <text x="528" y="351" text-anchor="middle" font-size="13" font-family={mono} font-weight="700" fill="var(--ink)">LLM</text>
    <line x1="502" y1="313" x2="502" y2="320" stroke="var(--ink)" stroke-width="1.3"></line>
    <line x1="518" y1="313" x2="518" y2="320" stroke="var(--ink)" stroke-width="1.3"></line>
    <line x1="534" y1="313" x2="534" y2="320" stroke="var(--ink)" stroke-width="1.3"></line>
    <line x1="550" y1="313" x2="550" y2="320" stroke="var(--ink)" stroke-width="1.3"></line>

    <line x1="566" y1="345" x2="606" y2="345" stroke="var(--muted)" stroke-width="1.5" marker-end="url(#sd2)"></line>
    <text x="648" y="350" font-size="11.5" font-family={mono} font-weight="700" fill="var(--ink)">answer</text>

    <!-- outcome feedback -->
    <path d="M 528 372 C 528 404, 260 410, 175 382" fill="none" stroke="var(--faint)" stroke-width="1.3" stroke-dasharray="4 3" marker-end="url(#sd2)"></path>
    <text x="390" y="414" text-anchor="middle" font-size="9.5" font-family={mono} fill="var(--faint)">outcome signal: train retrieval on what actually helped</text>
  </svg>
  <figcaption><strong>Fig. {num}.</strong> The memory lifecycle as a pipeline. Construction happens at the write gate, management is an offline worker over the stores, access is the per-query read path. The dashed outcome edge is the frontier: retrieval trained on task success instead of similarity (<a href="https://arxiv.org/abs/2508.19828">Memory-R1</a>, MemRL).</figcaption>
</figure>
