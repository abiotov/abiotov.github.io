---
// Fig 2 — ONE idea: the lifecycle is write -> store -> read, with an offline
// maintain loop. Four shapes, big text.
const { num = '2' } = Astro.props;
---
<figure class="fig">
  <svg viewBox="0 0 720 300" role="img" aria-label="Pipeline: experience flows through a write stage into a memory store; a read stage retrieves from the store into the context; a maintain loop runs over the store offline.">
    <defs>
      <marker id="f2a" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M 0 1 L 9 5 L 0 9 z" fill="var(--muted)"></path>
      </marker>
    </defs>

    <text x="16" y="130" font-size="17" fill="var(--ink)">experience</text>
    <text x="16" y="152" font-size="13" fill="var(--muted)">turns, tool results</text>

    <line x1="118" y1="138" x2="158" y2="138" stroke="var(--muted)" stroke-width="2" marker-end="url(#f2a)"></line>

    <!-- write -->
    <rect x="162" y="102" width="130" height="72" rx="10" fill="none" stroke="var(--ink)" stroke-width="2"></rect>
    <text x="227" y="132" text-anchor="middle" font-size="19" font-weight="600" fill="var(--ink)">write</text>
    <text x="227" y="156" text-anchor="middle" font-size="13" fill="var(--muted)">extract, gate</text>
    <text x="227" y="196" text-anchor="middle" font-size="13" fill="var(--faint)">construction</text>

    <line x1="292" y1="138" x2="330" y2="138" stroke="var(--muted)" stroke-width="2" marker-end="url(#f2a)"></line>

    <!-- store -->
    <path d="M 334 96 a 62 15 0 0 1 124 0 v 84 a 62 15 0 0 1 -124 0 z" fill="var(--line)" stroke="var(--ink)" stroke-width="2"></path>
    <ellipse cx="396" cy="96" rx="62" ry="15" fill="var(--line)" stroke="var(--ink)" stroke-width="2"></ellipse>
    <text x="396" y="145" text-anchor="middle" font-size="19" font-weight="600" fill="var(--ink)">store</text>
    <text x="396" y="167" text-anchor="middle" font-size="12" fill="var(--muted)">items · graph · log</text>

    <!-- maintain loop above store -->
    <path d="M 362 66 C 354 46, 438 46, 430 66" fill="none" stroke="var(--muted)" stroke-width="2" marker-end="url(#f2a)"></path>
    <text x="396" y="16" text-anchor="middle" font-size="17" font-weight="600" fill="var(--ink)">maintain</text>
    <text x="396" y="36" text-anchor="middle" font-size="13" fill="var(--muted)">offline: consolidate, dedup, decay</text>
    <text x="522" y="36" font-size="13" fill="var(--faint)">management</text>

    <line x1="460" y1="138" x2="498" y2="138" stroke="var(--muted)" stroke-width="2" marker-end="url(#f2a)"></line>

    <!-- read -->
    <rect x="502" y="102" width="130" height="72" rx="10" fill="none" stroke="var(--ink)" stroke-width="2"></rect>
    <text x="567" y="132" text-anchor="middle" font-size="19" font-weight="600" fill="var(--ink)">read</text>
    <text x="567" y="156" text-anchor="middle" font-size="13" fill="var(--muted)">retrieve, assemble</text>
    <text x="567" y="196" text-anchor="middle" font-size="13" fill="var(--faint)">access</text>

    <line x1="632" y1="138" x2="656" y2="138" stroke="var(--muted)" stroke-width="2" marker-end="url(#f2a)"></line>
    <text x="718" y="132" text-anchor="end" font-size="16" fill="var(--ink)">context</text>
    <text x="718" y="152" text-anchor="end" font-size="13" fill="var(--muted)">tokens</text>

    <!-- the trap, one line -->
    <text x="360" y="262" text-anchor="middle" font-size="15" fill="var(--muted)">squeeze one stage and the cost pops out of another:</text>
    <text x="360" y="284" text-anchor="middle" font-size="15" fill="var(--muted)">over-compress writes, pay in repairs; skip maintenance, drown retrieval</text>
  </svg>
  <figcaption><strong>Fig. {num}.</strong> The memory lifecycle from <a href="https://arxiv.org/abs/2601.14192">Toward Efficient Agents</a>: construction at write time, management between interactions, access at query time. Every system in this post is a set of choices inside these four boxes.</figcaption>
</figure>
