---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { posts } from '../../data/site.js';

const fmtDate = (d) => {
  const [y, m, day] = d.split('-');
  return new Date(Date.UTC(+y, +m - 1, +day)).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
  });
};
---

<Base title="Writing · Abiotov" description="Notes on building AI systems in production.">
  <Header active="writing" />

  <main class="wrap">
    <section class="hero">
      <h1>Writing</h1>
      <p class="lede">Notes on building AI systems in production.</p>
    </section>

    <section>
      {posts.map((p) => (
        <a class="post-row" href={p.href}>
          <span class="row-top">
            <span class="post-title">{p.title}</span>
            <span class="post-date">{fmtDate(p.date)}</span>
          </span>
          {p.excerpt && <span class="post-excerpt">{p.excerpt}</span>}
        </a>
      ))}
    </section>
  </main>

  <Footer />
</Base>
