---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    title: 'A real calendar server in your test suite',
    date: '2026-07-17',
    href: '/writing/radicale-pytest/',
    excerpt: 'Run Radicale in-process as a pytest fixture: real CalDAV integration tests, no Docker.',
  },
  {
    title: 'Agent memory: what exists, what breaks, and what nobody measures',
    date: '2026-07-14',
    href: '/writing/agent-memory/',
    excerpt: 'A field guide to memory for LLM agents, with the benchmark numbers fact-checked.',
  },
];

const fmtDate = (d) => {
  const [y, m, day] = d.split('-');
  return new Date(Date.UTC(+y, +m - 1, +day)).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
  });
};
---

<Base title="Writing · Abiotov" description="Notes on building AI systems in production.">
  <Header active="writing" />

  <main class="wrap">
    <section class="hero">
      <h1>Writing</h1>
      <p class="lede">Notes on building AI systems in production.</p>
    </section>

    <section>
      {posts.map((p) => (
        <a class="post-row" href={p.href}>
          <span class="row-top">
            <span class="post-title">{p.title}</span>
            <span class="post-date">{fmtDate(p.date)}</span>
          </span>
          {p.excerpt && <span class="post-excerpt">{p.excerpt}</span>}
        </a>
      ))}
    </section>
  </main>

  <Footer />
</Base>
