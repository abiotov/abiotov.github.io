---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const posts = [
  { title: 'Agent memory: what exists, what breaks, and what nobody measures', date: '2026-07-14', href: '/writing/agent-memory/' },
  { title: 'Agentic RAG, explained', date: '2026-06-19', href: '/writing/agentic-rag/' },
  { title: 'Embedding clickable tweets in articles', date: '2026-06-15', href: '/writing/embedding-tweets/' },
];

const fmtDate = (d) => {
  const [y, m, day] = d.split('-');
  return new Date(Date.UTC(+y, +m - 1, +day)).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
  });
};
---

<Base>
  <header class="site-header">
    <div class="wrap nav">
      <a class="brand" href="/">Etienne Tovimafa</a>
      <nav class="nav-links">
        <a href="https://github.com/abiotov" target="_blank" rel="noopener">github</a>
        <ThemeToggle />
      </nav>
    </div>
  </header>

  <main class="wrap">
    <section class="bio">
      <p class="bio-intro">Etienne Tovimafa is an AI engineer working on applied LLM systems in production. He builds end-to-end systems across retrieval-augmented generation, agentic workflows, real-time voice, LLM evaluation, and resilient multi-provider infrastructure. His focus is taking AI from prototype to production behind real users — where grounding, reliability, and evaluation are what actually matter.</p>
      <div class="bio-links">
        <a href="https://github.com/abiotov" target="_blank" rel="noopener">GitHub</a>
        <a href="https://linkedin.com/in/etiennetovi" target="_blank" rel="noopener">LinkedIn</a>
        <a href="mailto:abiodouneti@gmail.com">Email</a>
      </div>
    </section>

    <section>
      {posts.map((p) => (
        <a class="post-row" href={p.href}>
          <span class="row-top">
            <span class="post-title">{p.title}</span>
            <span class="post-date">{fmtDate(p.date)}</span>
          </span>
        </a>
      ))}
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap"><p class="colophon">© 2026 Etienne Tovimafa</p></div>
  </footer>
</Base>
