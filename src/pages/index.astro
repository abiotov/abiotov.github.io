---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const posts = [
  { title: 'A real calendar server in your test suite', date: '2026-07-17', href: '/writing/radicale-pytest/' },
  { title: 'Agent memory: what exists, what breaks, and what nobody measures', date: '2026-07-14', href: '/writing/agent-memory/' },
];

const fmtDate = (d) => {
  const [y, m, day] = d.split('-');
  return new Date(Date.UTC(+y, +m - 1, +day)).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
  });
};
---

<Base>
  <header class="site-header">
    <div class="wrap nav">
      <a class="brand" href="/">Abiotov</a>
      <nav class="nav-links">
        <a href="https://github.com/abiotov" target="_blank" rel="noopener">github</a>
        <ThemeToggle />
      </nav>
    </div>
  </header>

  <main class="wrap">
    <section class="bio">
      <p class="bio-intro">Abiotov is an AI engineer working on applied LLM systems in production. He builds end-to-end systems across retrieval-augmented generation, agentic workflows, real-time voice, LLM evaluation, and resilient multi-provider infrastructure. His focus is taking AI from prototype to production behind real users: where grounding, reliability, and evaluation are what actually matter.</p>
      <div class="bio-links">
        <a href="https://github.com/abiotov" target="_blank" rel="noopener">GitHub</a>
        <a href="https://linkedin.com/in/etiennetovi" target="_blank" rel="noopener">LinkedIn</a>
        <a href="mailto:abiodouneti@gmail.com">Email</a>
      </div>
    </section>

    <section id="projects">
      <h2 class="section-label">Projects</h2>
      <a class="post-row" href="https://github.com/abiotov/polyglot-booking-agent" target="_blank" rel="noopener">
        <span class="row-top">
          <span class="post-title">Polyglot Booking Agent</span>
          <span class="post-date">Python</span>
        </span>
        <span class="post-excerpt">Multilingual voice agent for appointment booking: deterministic scheduling engine, CalDAV as the single source of truth, FR/EN mid-call language switching, scenario-based evals.</span>
      </a>
      <p class="building">More experiments and open source on <a href="https://github.com/abiotov" target="_blank" rel="noopener">GitHub</a>.</p>
    </section>

    <section id="writing">
      <h2 class="section-label">Writing</h2>
      {posts.map((p) => (
        <a class="post-row" href={p.href}>
          <span class="row-top">
            <span class="post-title">{p.title}</span>
            <span class="post-date">{fmtDate(p.date)}</span>
          </span>
        </a>
      ))}
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap"><p class="colophon">© 2026 Abiotov</p></div>
  </footer>
</Base>
