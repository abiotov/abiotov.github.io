---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SocialIcons from '../components/SocialIcons.astro';
import ProjectCover from '../components/ProjectCover.astro';
import { posts, projects } from '../data/site.js';

const fmtDate = (d) => {
  const [y, m, day] = d.split('-');
  return new Date(Date.UTC(+y, +m - 1, +day)).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC',
  });
};
---

<Base>
  <Header active="home" />

  <main class="wrap">
    <section class="bio">
      <h1 class="hero-title">Hi, I'm Abiotov.</h1>
      <p class="bio-intro">AI engineer working on applied LLM systems in production. I build end-to-end systems across retrieval-augmented generation, agentic workflows, real-time voice, LLM evaluation, and resilient multi-provider infrastructure. My focus is taking AI from prototype to production behind real users: where grounding, reliability, and evaluation are what actually matter.</p>
      <div class="bio-icons">
        <SocialIcons size={20} />
      </div>
    </section>

    <section id="projects">
      <h2 class="section-label">Projects</h2>
      <div class="cards">
        {projects.map((p) => (
          <article class="card">
            <ProjectCover kind={p.cover} />
            <a class="card-title" href={p.href} target="_blank" rel="noopener">{p.title}</a>
            <span class="card-tag">{p.tag}</span>
            <p class="card-desc">{p.desc}</p>
            <div class="card-links">
              {p.links.map((l) => (
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel={l.href.startsWith('http') ? 'noopener' : undefined}>{l.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
      <p class="building">More experiments and open source on <a href="https://github.com/abiotov" target="_blank" rel="noopener">GitHub</a>.</p>
    </section>

    <section id="writing">
      <h2 class="section-label">Writing</h2>
      {posts.map((p) => (
        <a class="post-row" href={p.href}>
          <span class="row-top">
            <span class="post-title">{p.title}</span>
            <span class="post-date">{fmtDate(p.date)}</span>
          </span>
        </a>
      ))}
    </section>
  </main>

  <Footer />
</Base>
